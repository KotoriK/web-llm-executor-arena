---
interface Props {
  id: string;
  data: any[];
  title: string;
  class?: string;
}

const { id, data, title, class: className = '' } = Astro.props;

// Format data for ECharts bar chart
const runtimes = data.map(d => d.runtime);
const loadTimes = data.map(d => (d.loadTime.mean / 1000).toFixed(1)); // Convert to seconds
const ttfts = data.map(d => d.ttft.mean.toFixed(0)); // milliseconds
const tps = data.map(d => d.tokensPerSecond.mean.toFixed(1));
---

<div class={`chart-container ${className}`}>
  <div id={id} style="width: 100%; height: 400px;"></div>
</div>

<script define:vars={{ id, runtimes, loadTimes, ttfts, tps, title }}>
  import * as echarts from 'echarts';

  document.addEventListener('DOMContentLoaded', () => {
    const chartDom = document.getElementById(id);
    if (!chartDom) return;

    const myChart = echarts.init(chartDom);
    
    const option = {
      title: {
        text: title,
        left: 'center',
        textStyle: {
          fontSize: 18,
          fontWeight: 'bold'
        }
      },
      tooltip: {
        trigger: 'axis',
        axisPointer: {
          type: 'shadow'
        }
      },
      legend: {
        data: ['Load Time (s)', 'TTFT (ms)', 'Tokens/sec'],
        top: 40
      },
      grid: {
        left: '3%',
        right: '4%',
        bottom: '3%',
        containLabel: true
      },
      xAxis: {
        type: 'category',
        data: runtimes,
        axisLabel: {
          interval: 0,
          rotate: 30
        }
      },
      yAxis: [
        {
          type: 'value',
          name: 'Load Time (s) / TTFT (ms)',
          position: 'left',
        },
        {
          type: 'value',
          name: 'Tokens/sec',
          position: 'right',
        }
      ],
      series: [
        {
          name: 'Load Time (s)',
          type: 'bar',
          data: loadTimes,
          itemStyle: {
            color: '#0ea5e9'
          }
        },
        {
          name: 'TTFT (ms)',
          type: 'bar',
          data: ttfts,
          itemStyle: {
            color: '#8b5cf6'
          }
        },
        {
          name: 'Tokens/sec',
          type: 'bar',
          yAxisIndex: 1,
          data: tps,
          itemStyle: {
            color: '#10b981'
          }
        }
      ]
    };

    myChart.setOption(option);

    // Make chart responsive
    window.addEventListener('resize', () => {
      myChart.resize();
    });
  });
</script>
