{
  "name": "web-llm-executor-arena-automation",
  "version": "1.0.0",
  "description": "Automated testing framework for LLM runtime performance benchmarking",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:demo": "playwright test tests/demo.test.ts",
    "test:wllama": "playwright test tests/wllama.test.ts",
    "test:webllm": "playwright test tests/webllm.test.ts",
    "test:transformers": "playwright test tests/transformers.test.ts",
    "test:mediapipe": "playwright test tests/mediapipe.test.ts",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "serve": "http-server test-pages -p 3000 -c-1 --cors",
    "setup": "echo 'Installing test page dependencies...' && cd test-pages/wllama && pnpm install || npm install",
    "setup:webllm": "cd test-pages/webllm && pnpm install || npm install"
  },
  "keywords": [
    "playwright",
    "llm",
    "performance",
    "testing",
    "benchmark"
  ],
  "author": "KotoriK",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "http-server": "^14.1.1"
  }
}
